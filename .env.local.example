# Supabase — Werte aus dem Supabase-Dashboard (Project Settings -> API).
# Echte Werte gehoeren NUR in .env.local (gitignored), NIEMALS in diese Datei
# oder ins Repo.

# Beide NEXT_PUBLIC-Keys sind fuer den Browser bestimmt und durch RLS abgesichert.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role-Key (Scheibe 2a): GEHEIM, bypassed RLS. NUR server-only genutzt
# (src/lib/supabase/admin.ts, import "server-only"). NON-NEXT_PUBLIC -> landet nie
# im Client-Bundle. NIEMALS in eine Client-Komponente oder in den Export.
SUPABASE_SERVICE_ROLE_KEY=

# App-URL (Scheibe 2b-ii): OEFFENTLICH (kein Secret). Wird in den Export gebacken —
# der Client-Beacon (sendBeacon) zielt auf ${NEXT_PUBLIC_APP_URL}/api/capi. Muss
# ABSOLUT sein, weil der Export auf fremder Domain laeuft. Dev: http://localhost:3000;
# Prod: die Pagesmith-Domain (im Vercel-Project-Env setzen). Fehlt/leer -> KEIN Beacon
# + console.warn (fail-loud, kein relativer Fallback).
NEXT_PUBLIC_APP_URL=

# Serving-Basis-Domain (Phase 7): Basis der Live-URL publizierter Projekte
# (<label>.<domain>). OEFFENTLICH, kein Secret; wird build-zeit ins Client-Bundle
# inlined. Ohne Protokoll, ohne trailing slash — https wird automatisch abgeleitet
# (Ausnahme: localhost / *.lvh.me -> http). Leer in Prod -> publizierte Projekte
# erhalten keine Live-URL (fail-loud console.warn beim Publish).
NEXT_PUBLIC_HOSTING_DOMAIN=lvh.me:3000  # Dev. Prod: publayer.net (ohne Port)
